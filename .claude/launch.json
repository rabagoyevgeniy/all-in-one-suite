{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Dev Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5234"],
      "port": 5234
    },
    {
      "name": "Vite Preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "preview"],
      "port": 4173
    },
    {
      "name": "Vitest Watch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:watch"],
      "port": 0
    },
    {
      "name": "Supabase Local",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["supabase", "start"],
      "port": 54321
    },
    {
      "name": "VibeCoding Dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["start-vibecoding.cjs"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
